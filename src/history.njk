---
layout: base.njk
---

<div class="mb-8 border-b pb-4">
  <h2 class="text-3xl font-serif font-bold">Historical Digests</h2>
  <p class="text-gray-600 mt-2">Browse daily and weekly collections.</p>
</div>

<div class="grid grid-cols-1 md:grid-cols-2 gap-8">
  <section>
    <h3 class="text-2xl font-serif font-bold mb-4">Daily Digests</h3>
    <ul class="space-y-2">
      {% for dateKey, digest in history.daily %}
        {% if digest.date %}
        <li>
          <a href="{{ '/daily/' + dateKey + '/' | url }}" class="text-blue-600 hover:underline">
            {{ digest.date | readableDate }} ({{ digest.articleCount }} articles)
          </a>
        </li>
        {% endif %}
      {% else %}
        <li class="text-gray-500">No daily digests available.</li>
      {% endfor %}
    </ul>
  </section>

  <section>
    <h3 class="text-2xl font-serif font-bold mb-4">Weekly Digests</h3>
    <ul class="space-y-2">
      {% for dateKey, digest in history.weekly %}
        {% if digest.date %}
        <li>
          <a href="{{ '/weekly/' + dateKey + '/' | url }}" class="text-blue-600 hover:underline">
            Week of {{ digest.date | readableDate }} ({{ digest.articleCount }} articles)
          </a>
        </li>
        {% endif %}
      {% else %}
        <li class="text-gray-500">No weekly digests available.</li>
      {% endfor %}
    </ul>
  </section>
</div>
