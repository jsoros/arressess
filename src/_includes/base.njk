<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>The Digest</title>
  <link rel="stylesheet" href="{{ '/assets/style.css' | url }}">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&family=Merriweather:ital,wght@0,300;0,700;1,300&display=swap" rel="stylesheet">
</head>
<body class="bg-gray-50 text-gray-900 font-sans antialiased">
  <header class="py-8 bg-white border-b border-gray-200">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex flex-col md:flex-row justify-between items-center gap-4">
      <h1 class="text-4xl font-serif font-bold text-gray-900 tracking-tight"><a href="{{ '/' | url }}">The Digest</a></h1>
      <nav class="flex items-center space-x-6 text-sm font-semibold uppercase tracking-widest text-gray-500">
        <a href="{{ '/' | url }}" class="hover:text-blue-600 transition-colors">Latest</a>
        <a href="{{ '/history/' | url }}" class="hover:text-blue-600 transition-colors">History</a>
      </nav>
    </div>
  </header>

  <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    {{ content | safe }}
  </main>

  <footer class="bg-white border-t border-gray-200 mt-16 py-8">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center text-gray-500 text-sm">
      <p>Generated by GitHub Actions • Built with Eleventy</p>
    </div>
  </footer>
</body>
</html>
