<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>The Digest</title>
  <link rel="stylesheet" href="{{ '/assets/style.css' | url }}">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Lato:ital,wght@0,300;0,400;0,700;1,300;1,400;1,700&family=Merriweather:ital,wght@0,300;0,700;1,300&display=swap" rel="stylesheet">
</head>
<body class="bg-chirpy-bg text-chirpy-text font-sans antialiased flex flex-col md:flex-row min-h-screen">

  <!-- Sidebar for Desktop -->
  <aside class="hidden md:flex flex-col w-64 fixed inset-y-0 bg-sidebar-bg text-sidebar-text border-r border-gray-800 z-50">
    <div class="flex-grow flex flex-col pt-12 pb-6 px-6">
      <div class="text-center mb-10">
        <h1 class="text-2xl font-bold text-white tracking-wide"><a href="{{ '/' | url }}">The Digest</a></h1>
        <p class="text-sm mt-2 text-gray-400">Curated daily news & articles</p>
      </div>

      <nav class="flex-grow flex flex-col space-y-4 text-lg">
        <a href="{{ '/' | url }}" class="flex items-center py-2 px-3 rounded-md hover:bg-gray-800 hover:text-sidebar-hover transition-colors">
          <svg class="w-5 h-5 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"></path></svg>
          Latest
        </a>
        <a href="{{ '/history/' | url }}" class="flex items-center py-2 px-3 rounded-md hover:bg-gray-800 hover:text-sidebar-hover transition-colors">
          <svg class="w-5 h-5 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
          History
        </a>
      </nav>

      <div class="mt-auto text-center text-xs text-gray-500 pt-6">
        <p>Built with Eleventy</p>
      </div>
    </div>
  </aside>

  <!-- Top bar for Mobile -->
  <header class="md:hidden bg-sidebar-bg text-white flex items-center justify-between px-4 py-3 sticky top-0 z-40">
    <h1 class="text-xl font-bold tracking-wide"><a href="{{ '/' | url }}">The Digest</a></h1>
    <nav class="flex space-x-4 text-sm font-semibold">
      <a href="{{ '/' | url }}" class="hover:text-gray-300">Latest</a>
      <a href="{{ '/history/' | url }}" class="hover:text-gray-300">History</a>
    </nav>
  </header>

  <!-- Main Content -->
  <div class="flex-grow md:ml-64 flex flex-col min-h-screen relative">
    <main class="flex-grow max-w-4xl w-full mx-auto px-4 sm:px-6 lg:px-8 py-8 md:py-12">
      {{ content | safe }}
    </main>

    <footer class="border-t border-chirpy-border py-8 mt-auto bg-white/50">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center text-chirpy-meta text-sm">
        <p>Generated by GitHub Actions • The Digest Aggregator</p>
      </div>
    </footer>
  </div>
</body>
</html>
