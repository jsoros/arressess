---
layout: base.njk
pagination:
  data: history.weekly
  size: 1
  alias: dateKey
permalink: "weekly/{{ dateKey }}/index.html"
---

{% set digest = history.weekly[dateKey] %}
<div class="mb-8 border-b pb-4">
  <h2 class="text-3xl font-serif font-bold">Weekly Digest: {{ digest.date | readableDate }}</h2>
  <p class="text-gray-600 mt-2">Found {{ digest.articleCount }} articles.</p>
</div>

{% if digest.articles.length > 0 %}
  <div class="space-y-4">
    {% for article in digest.articles %}
      <details class="bg-white rounded shadow-sm border border-gray-200 group cursor-pointer overflow-hidden">
        <summary class="p-4 flex flex-col md:flex-row md:items-center justify-between hover:bg-gray-50 outline-none list-none [&::-webkit-details-marker]:hidden">
          <div class="flex-grow pr-4">
            <span class="text-xs font-bold uppercase text-blue-600 tracking-wider mb-1 block">{{ article.feedTitle }}</span>
            <h3 class="text-lg font-serif font-bold text-gray-900 group-hover:text-blue-700 transition-colors">{{ article.title }}</h3>
          </div>
          <div class="flex items-center space-x-4 mt-2 md:mt-0 text-sm text-gray-500 whitespace-nowrap">
            <time>{{ article.pubDate | readableDate }}</time>
            <svg class="w-5 h-5 transform transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
          </div>
        </summary>
        <div class="p-4 border-t border-gray-100 bg-gray-50 flex flex-col md:flex-row gap-6">
          {% if article.imageUrl %}
            <div class="w-full md:w-1/4 h-32 relative flex-shrink-0">
               <img src="{{ article.imageUrl }}" class="w-full h-full object-cover rounded" alt="">
            </div>
          {% endif %}
          <div class="flex-grow">
            <p class="text-gray-700 text-sm mb-4 leading-relaxed">{{ article.snippet | safe }}</p>
            <a href="{{ article.link }}" target="_blank" rel="noopener noreferrer" class="inline-flex items-center text-sm font-semibold text-blue-600 hover:text-blue-800 transition-colors">
              Read Full Article &rarr;
            </a>
          </div>
        </div>
      </details>
    {% endfor %}
  </div>
{% else %}
  <div class="text-center py-20">
    <h2 class="text-2xl font-serif font-bold text-gray-400">No stories found for this week.</h2>
  </div>
{% endif %}
