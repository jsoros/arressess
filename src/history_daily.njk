---
layout: base.njk
pagination:
  data: history.daily
  size: 1
  alias: dateKey
permalink: "daily/{{ dateKey }}/index.html"
---

{% set digest = history.daily[dateKey] %}
<div class="mb-10 border-b border-chirpy-border pb-4">
  <h2 class="text-3xl font-bold mb-2">Daily Digest: {{ digest.date | readableDate }}</h2>
  <p class="text-chirpy-meta">Found {{ digest.articleCount }} articles.</p>
</div>

{% if digest.articles.length > 0 %}
  <div class="flex flex-col">
    {% for article in digest.articles %}
      <article class="bg-chirpy-card hover:bg-gray-50 transition-colors py-3 px-4 flex flex-col border-b border-chirpy-border">
        <div class="flex-grow flex flex-col">
          <h2 class="text-lg font-bold mb-1 leading-tight">
            <a href="{{ article.link }}" target="_blank" rel="noopener noreferrer" class="text-chirpy-text hover:text-chirpy-link transition-colors">{{ article.title }}</a>
          </h2>

          <div class="text-chirpy-meta text-xs flex items-center space-x-2">
            <time>{{ article.pubDate | readableDate }}</time>
            <span>&middot;</span>
            <span class="bg-gray-100 px-2 py-0.5 rounded text-xs text-gray-700">{{ article.feedTitle }}</span>
          </div>
        </div>
      </article>
    {% endfor %}
  </div>
{% else %}
  <div class="text-center py-20">
    <h2 class="text-2xl font-bold text-gray-400">No stories found for this date.</h2>
  </div>
{% endif %}
