---
layout: base.njk
---

<div class="space-y-6">
{% if latest_daily.articles.length > 0 %}
  {% for article in latest_daily.articles %}
    <article class="bg-chirpy-card rounded-xl shadow-sm hover:shadow-md transition-shadow p-6 flex flex-col sm:flex-row gap-6 border border-chirpy-border">
      <div class="flex-grow flex flex-col">
        <h2 class="text-2xl font-bold mb-2">
          <a href="{{ article.link }}" target="_blank" rel="noopener noreferrer" class="text-chirpy-text hover:text-chirpy-link transition-colors">{{ article.title }}</a>
        </h2>

        <div class="text-chirpy-meta text-sm flex items-center space-x-3 mb-4">
          <time>{{ article.pubDate | readableDate }}</time>
          <span>&middot;</span>
          <span class="bg-gray-100 px-2 py-0.5 rounded text-xs text-gray-700">{{ article.feedTitle }}</span>
        </div>

        <p class="text-gray-600 mb-4 line-clamp-3 leading-relaxed flex-grow">{{ article.snippet | safe }}</p>

        <div class="mt-auto">
           <a href="{{ article.link }}" target="_blank" rel="noopener noreferrer" class="text-chirpy-link hover:text-chirpy-linkHover text-sm font-semibold uppercase tracking-wider transition-colors inline-flex items-center">
             Read more
             <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
           </a>
        </div>
      </div>

      {% if article.imageUrl %}
        <div class="sm:w-1/3 sm:min-w-[200px] shrink-0 h-48 sm:h-auto relative overflow-hidden rounded-lg">
          <img src="{{ article.imageUrl }}" alt="Cover image for {{ article.title }}" class="absolute inset-0 w-full h-full object-cover">
        </div>
      {% endif %}
    </article>
  {% endfor %}
{% else %}
  <div class="text-center py-20">
    <h2 class="text-2xl font-bold text-gray-400">No new stories right now.</h2>
    <p class="text-gray-500 mt-2">Check back later or adjust your config.</p>
  </div>
{% endif %}
</div>
