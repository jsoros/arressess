---
layout: base.njk
---

{% if latest_daily.articles.length > 0 %}
  {% set heroArticle = latest_daily.articles[0] %}
  <section class="mb-16">
    <article class="bg-white rounded-lg shadow-sm overflow-hidden flex flex-col md:flex-row group transition-all duration-300 hover:shadow-md">
      {% if heroArticle.imageUrl %}
        <div class="md:w-2/3 h-64 md:h-auto relative overflow-hidden">
          <img src="{{ heroArticle.imageUrl }}" alt="Cover image for {{ heroArticle.title }}" class="absolute inset-0 w-full h-full object-cover transition-transform duration-500 group-hover:scale-105">
        </div>
      {% endif %}
      <div class="p-8 md:p-12 {% if heroArticle.imageUrl %}md:w-1/3 flex flex-col justify-center{% else %}w-full{% endif %}">
        <div class="flex items-center space-x-2 mb-4">
          <span class="bg-black text-white text-xs font-bold uppercase px-2 py-1 tracking-wider">{{ heroArticle.feedTitle }}</span>
          <time class="text-sm text-gray-500">{{ heroArticle.pubDate | readableDate }}</time>
        </div>
        <h2 class="text-3xl md:text-4xl font-serif font-bold leading-tight mb-4 group-hover:text-blue-700 transition-colors duration-300">
          <a href="{{ heroArticle.link }}" target="_blank" rel="noopener noreferrer" class="hover:underline">{{ heroArticle.title }}</a>
        </h2>
        <p class="text-gray-600 leading-relaxed mb-6">{{ heroArticle.snippet | safe }}</p>
        <a href="{{ heroArticle.link }}" target="_blank" rel="noopener noreferrer" class="inline-flex items-center font-semibold text-black hover:text-blue-700 transition-colors">
          Read Full Story
          <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
        </a>
      </div>
    </article>
  </section>

  {% if latest_daily.articles.length > 1 %}
    <section>
      <div class="flex items-center mb-8">
        <h3 class="text-2xl font-serif font-bold mr-4">More Stories</h3>
        <div class="flex-grow h-px bg-gray-200"></div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {% for article in latest_daily.articles %}
          {% if loop.index0 > 0 %}
            <article class="bg-white rounded-lg shadow-sm overflow-hidden flex flex-col group transition-all duration-300 hover:shadow-md h-full">
              {% if article.imageUrl %}
                <div class="h-48 relative overflow-hidden">
                  <img src="{{ article.imageUrl }}" alt="Cover image for {{ article.title }}" class="absolute inset-0 w-full h-full object-cover transition-transform duration-500 group-hover:scale-105">
                </div>
              {% endif %}
              <div class="p-6 flex flex-col flex-grow">
                <div class="flex items-center justify-between mb-3">
                  <span class="text-xs font-bold uppercase text-blue-600 tracking-wider">{{ article.feedTitle }}</span>
                </div>
                <h4 class="text-xl font-serif font-bold leading-snug mb-3 group-hover:text-blue-700 transition-colors duration-300">
                  <a href="{{ article.link }}" target="_blank" rel="noopener noreferrer" class="hover:underline">{{ article.title }}</a>
                </h4>
                <p class="text-gray-600 text-sm flex-grow mb-4">{{ article.snippet | safe }}</p>
                <div class="mt-auto flex items-center justify-between text-xs text-gray-500">
                  <time>{{ article.pubDate | readableDate }}</time>
                  <a href="{{ article.link }}" target="_blank" rel="noopener noreferrer" class="font-semibold text-black hover:text-blue-700 transition-colors">Read &rarr;</a>
                </div>
              </div>
            </article>
          {% endif %}
        {% endfor %}
      </div>
    </section>
  {% endif %}

{% else %}
  <div class="text-center py-20">
    <h2 class="text-2xl font-serif font-bold text-gray-400">No new stories right now.</h2>
    <p class="text-gray-500 mt-2">Check back later or adjust your config.</p>
  </div>
{% endif %}
